# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# local MCP config — contains the Figma personal access token (use .mcp.json.example as a template)
.mcp.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# external Figma tool — clone it yourself: git clone https://github.com/plugin87/figma-rest-api
/figma-rest-api

# Figma Make tooling cache (local-only, no committed contents)
/.figma

# Figma round-trip practice outputs (figma-pull --out; local-only, regenerate anytime)
/before.json
/after.json

# storybook build output
/storybook-static

# playwright-cli snapshots / console logs (browser automation artifacts)
/.playwright-cli

*storybook.log
storybook-static
